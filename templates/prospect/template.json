{
  "name": "Personalized prospect landing page",
  "description": "Outbound prospecting microsite — personalized by persona, company and industry, with competitor context",
  "nameField": "company",
  "fields": [
    { "id": "first_name",      "label": "First name",            "type": "text",     "required": true,  "max": 60,  "group": "Prospect",        "default": "Sarah",    "placeholder": "e.g. Sarah" },
    { "id": "last_name",       "label": "Last name",             "type": "text",     "required": true,  "max": 60,  "group": "Prospect",        "default": "Chen",     "placeholder": "e.g. Chen" },
    { "id": "title",           "label": "Job title",             "type": "text",     "required": false, "max": 100, "group": "Prospect",        "default": "VP of Marketing", "placeholder": "e.g. VP of Marketing" },
    { "id": "company",         "label": "Company name",          "type": "text",     "required": true,  "max": 80,  "group": "Prospect",        "default": "Acme Corp", "placeholder": "e.g. Acme Corp" },
    { "id": "industry",        "label": "Industry",              "type": "text",     "required": false, "max": 80,  "group": "Prospect",        "default": "SaaS",     "placeholder": "e.g. SaaS, Healthcare, Finance…" },
    { "id": "hero_headline",   "label": "Hero headline",         "type": "text",     "required": true,  "max": 120, "group": "Messaging",       "default": "The webinar platform built for teams like yours.", "hint": "Main headline in the hero section" },
    { "id": "hero_sub",        "label": "Hero sub-headline",     "type": "textarea", "required": true,  "max": 300, "group": "Messaging",       "default": "Livestorm helps marketing teams run high-converting webinars, product demos, and virtual events — without the complexity.", "hint": "2–3 sentences that speak directly to their pain" },
    { "id": "challenge_1",     "label": "Challenge 1",           "type": "text",     "required": true,  "max": 100, "group": "Their challenges", "default": "Scattered tools slow down event production", "placeholder": "e.g. Fragmented tools slow down execution" },
    { "id": "challenge_2",     "label": "Challenge 2",           "type": "text",     "required": true,  "max": 100, "group": "Their challenges", "default": "Low attendee engagement hurts pipeline quality", "placeholder": "e.g. Low registration-to-show rates" },
    { "id": "challenge_3",     "label": "Challenge 3",           "type": "text",     "required": false, "max": 100, "group": "Their challenges", "default": "Hard to prove event ROI to the business", "placeholder": "e.g. No actionable post-event data" },
    { "id": "usecase_1_title", "label": "Use case 1 — title",   "type": "text",     "required": true,  "max": 60,  "group": "How Livestorm helps", "default": "One platform, every event format", "placeholder": "e.g. End-to-end webinar management" },
    { "id": "usecase_1_desc",  "label": "Use case 1 — detail",  "type": "textarea", "required": true,  "max": 220, "group": "How Livestorm helps", "default": "From registration pages to post-event replays, Livestorm handles every step — no plugins, no downloads, no duct-tape integrations.", "placeholder": "1–2 sentences" },
    { "id": "usecase_2_title", "label": "Use case 2 — title",   "type": "text",     "required": true,  "max": 60,  "group": "How Livestorm helps", "default": "Built-in engagement that converts", "placeholder": "e.g. Real-time engagement tools" },
    { "id": "usecase_2_desc",  "label": "Use case 2 — detail",  "type": "textarea", "required": true,  "max": 220, "group": "How Livestorm helps", "default": "Polls, Q&A with upvoting, CTAs, and chat keep your audience active. Every interaction is captured and flows into your CRM automatically.", "placeholder": "1–2 sentences" },
    { "id": "usecase_3_title", "label": "Use case 3 — title",   "type": "text",     "required": false, "max": 60,  "group": "How Livestorm helps", "default": "Analytics that prove ROI", "placeholder": "e.g. Pipeline-ready event data" },
    { "id": "usecase_3_desc",  "label": "Use case 3 — detail",  "type": "textarea", "required": false, "max": 220, "group": "How Livestorm helps", "default": "Attendance rates, engagement scores, replay views — all surfaced in real time and synced to Salesforce or HubSpot so you can measure what's working.", "placeholder": "1–2 sentences" },
    { "id": "comp_1_name",     "label": "Competitor 1",          "type": "text",     "required": false, "max": 60,  "group": "Competitive landscape", "default": "Zoom Webinars", "placeholder": "e.g. Zoom Webinars" },
    { "id": "comp_1_gap",      "label": "Competitor 1 — gap",   "type": "text",     "required": false, "max": 120, "group": "Competitive landscape", "default": "Built for meetings, not marketing events — limited registration flows and no built-in CRM sync", "placeholder": "Their main weakness vs Livestorm" },
    { "id": "comp_2_name",     "label": "Competitor 2",          "type": "text",     "required": false, "max": 60,  "group": "Competitive landscape", "default": "ON24", "placeholder": "e.g. ON24" },
    { "id": "comp_2_gap",      "label": "Competitor 2 — gap",   "type": "text",     "required": false, "max": 120, "group": "Competitive landscape", "default": "Enterprise-heavy, slow to set up, and expensive — hard to justify for growing teams", "placeholder": "Their main weakness vs Livestorm" },
    { "id": "comp_3_name",     "label": "Competitor 3",          "type": "text",     "required": false, "max": 60,  "group": "Competitive landscape", "default": "Demio", "placeholder": "e.g. Demio, GoToWebinar…" },
    { "id": "comp_3_gap",      "label": "Competitor 3 — gap",   "type": "text",     "required": false, "max": 120, "group": "Competitive landscape", "default": "Limited analytics, no on-demand experience, and weak CRM integrations", "placeholder": "Their main weakness vs Livestorm" },
    { "id": "am_name",         "label": "Your name",             "type": "text",     "required": true,  "max": 80,  "group": "Your details",    "default": "Alex Martin", "placeholder": "Your full name" },
    { "id": "am_title",        "label": "Your title",            "type": "text",     "required": false, "max": 80,  "group": "Your details",    "default": "Account Executive, Livestorm", "placeholder": "e.g. Account Executive, Livestorm" },
    { "id": "am_email",        "label": "Your email",            "type": "email",    "required": true,              "group": "Your details",    "default": "alex.martin@livestorm.co" },
    { "id": "cal_link",        "label": "Calendar / booking link", "type": "text",  "required": false, "max": 300, "group": "Your details",    "default": "", "placeholder": "https://cal.com/… or https://calendly.com/…", "hint": "Leave blank to use email as the CTA" }
  ]
}
